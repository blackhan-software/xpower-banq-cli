map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}
upstream xpowerbanq-db {
    server 127.0.0.1:8001;
}
server {
    listen 80 default_server;
    listen [::]:80 default_server;
    listen 443 ssl http2 default_server;
    listen [::]:443 ssl http2 default_server;

    server_name xpowerbanq.com;
    ssl_certificate /etc/ssl/certs/cf-xpowerbanq.com.crt;
    ssl_certificate_key /etc/ssl/private/cf-xpowerbanq.com.key;

    location = /robots.txt {
        default_type text/plain;
        return 200 "User-agent: *\nDisallow: /\n";
    }

    location / {
        proxy_pass http://xpowerbanq-db;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_http_version 1.1;
    }

    if ($http_user_agent ~* GoogleOther) {
        return 403;
    }
    if ($http_user_agent ~* GPTBot) {
        return 403;
    }
}
